# Database
DATABASE_URL=postgresql://user:password@localhost:5432/gmespay

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-this
JWT_ACCESS_TOKEN_EXPIRES=3600

# MonCash
MONCASH_CLIENT_ID=your_moncash_client_id
MONCASH_CLIENT_SECRET=your_moncash_secret
MONCASH_API_URL=https://api.moncashht.com/v1
MONCASH_WEBHOOK_SECRET=your_webhook_secret

# Stripe (pour cartes virtuelles)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Redis (pour cache et rate limiting)
REDIS_URL=redis://localhost:6379

# Email (pour notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_password

# Admin
ADMIN_EMAIL=admin@gmespay.com

# Taux de change (API externe)
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest/USD